DEMO_EMAIL=demo@yourtenant.onmicrosoft.com
DEMO_PASSWORD=
DEMO_TENANT=yourtenant
FFMPEG_PATH=  # leave blank to use ffmpeg-static default

# Optional: Copilot Studio environment name
DEMO_ENVIRONMENT=

# Anthropic API key — used to auto-generate callout text for demo slides
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Teams Incoming Webhook URL for completion/failure notifications
TEAMS_WEBHOOK_URL=

# Named profile credentials — used with --profile <name> in auth-standalone.js
# Pattern: PROFILE_{NAME}_EMAIL and PROFILE_{NAME}_PASSWORD
# Example: node scripts/auth-standalone.js --profile recipient
#   → reads PROFILE_RECIPIENT_EMAIL / PROFILE_RECIPIENT_PASSWORD
PROFILE_RECIPIENT_EMAIL=
PROFILE_RECIPIENT_PASSWORD=
